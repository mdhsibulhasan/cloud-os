async function openChat(userId,username,pic){
  activeChatUser={id:userId,name:username,pic:pic||''};
  document.querySelectorAll('.chat-item').forEach(i=>i.classList.remove('active'));
  event.currentTarget.classList.add('active');
  document.getElementById('chat-win').innerHTML=`
    <div class="chat-hdr" id="chat-hdr-main">
      <img src="${pic||'/assets/images/default-avatar.png'}" style="width:28px;height:28px;border-radius:50%;object-fit:cover;border:1px solid var(--border)" onerror="this.src='/assets/images/default-avatar.png'">
      <span>${username}</span>
      <span id="chat-hdr-status" style="font-size:.7rem;color:var(--green);margin-left:.4rem"></span>
    </div>
    <div class="chat-msgs" id="chat-msgs"><div style="color:var(--muted);font-size:.82rem;margin:auto;display:flex;align-items:center;gap:.5rem"><span class="spinner" style="width:16px;height:16px;border-width:2px"></span> Loading...</div></div>
    <div class="chat-inp">
      <input type="text" id="chat-input" placeholder="Type a message..." autocomplete="off"
             onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMsg();}"
             oninput="emitTyping(this.value.length>0)">
      <button class="btn-upload" style="padding:.5rem .9rem;flex-shrink:0" onclick="sendMsg()">
        <i class="fas fa-paper-plane"></i>
      </button>
    </div>`;
  await loadChatMessages(userId);
}

async function loadChatMessages(userId){
  try{
    const d=await api(`/messages?with=${userId}`);
    const msgs=d.conversation.messages;
    const container=document.getElementById('chat-msgs');
    if(!container)return;
    if(!msgs.length){
      container.innerHTML='<div style="color:var(--muted);font-size:.82rem;margin:auto;text-align:center">No messages yet.<br>Say hello! 👋</div>';
      return;
    }
    container.innerHTML=msgs.map((m,i)=>`
      <div class="msg ${m.isMine?'msg-out':'msg-in'}" style="animation:msgBubbleIn .25s ease-out ${i*20}ms both">
        <div>${escHtml(m.text)}</div>
        <div class="msg-time">${fmtDate(m.createdAt)}</div>
      </div>`).join('');
    container.scrollTop=container.scrollHeight;
  }catch(e){
    const container=document.getElementById('chat-msgs');
    if(container)container.innerHTML=`<div style="color:#ef4444;font-size:.82rem;margin:auto">${e.message}</div>`;
  }
}

let typingTimer=null;
function emitTyping(isTyping){
  if(!socket||!activeChatUser)return;
  socket.emit('typing',{to:activeChatUser.id,isTyping});
  if(isTyping){
    clearTimeout(typingTimer);
    typingTimer=setTimeout(()=>socket.emit('typing',{to:activeChatUser.id,isTyping:false}),2000);
  }
}

function escHtml(str){
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function appendMessage(text,isMine,createdAt){
  const container=document.getElementById('chat-msgs');
  if(!container)return;
  // Remove empty state if present
  const empty=container.querySelector('div[style*="margin:auto"]');
  if(empty)empty.remove();
  const msgEl=document.createElement('div');
  msgEl.className='msg '+(isMine?'msg-out':'msg-in');
  msgEl.style.animation='msgBubbleIn .3s cubic-bezier(0.34,1.56,0.64,1)';
  msgEl.innerHTML=`<div>${escHtml(text)}</div><div class="msg-time">${fmtDate(createdAt||new Date())}</div>`;
  container.appendChild(msgEl);
  container.scrollTop=container.scrollHeight;
}

async function sendMsg(){
  if(!activeChatUser)return;
  const input=document.getElementById('chat-input');
  if(!input)return;
  const text=input.value.trim();
  if(!text)return;
  input.value='';
  emitTyping(false);

  // Optimistic UI — show message immediately
  appendMessage(text,true,new Date());

  try{
    await api('/messages',{method:'POST',body:JSON.stringify({to:activeChatUser.id,text})});
    // Message confirmed — already shown optimistically
  }catch(e){
    toast(e.message,'err');
    // Remove the optimistic message on failure
    const container=document.getElementById('chat-msgs');
    if(container){
      const last=container.lastElementChild;
      if(last&&last.classList.contains('msg-out'))last.remove();
    }
  }
}

