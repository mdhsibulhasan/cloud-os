// ── PDF PREVIEW ──
async function previewFile(fileId,filename,mimetype){
  // First fetch the actual Cloudinary URL from our API
  let fileUrl = null;
  let downloadAllowed = true;
  try {
    const data = await api(`/files/preview/${fileId}`);
    fileUrl = data.url;
    downloadAllowed = data.downloadAllowed !== false;
  } catch(e) {
    toast('Could not load file: ' + e.message, 'error');
    return;
  }

  if (!fileUrl) { toast('File URL not found', 'error'); return; }

  // Use API-returned mimetype, fallback to filename/URL extension detection
  const effectiveMime = mimetype || '';
  const lname = filename.toLowerCase();
  const lurl = fileUrl.toLowerCase();
  const isPdf = effectiveMime.includes('pdf') || lname.endsWith('.pdf') || lurl.includes('.pdf');
  const isImg = effectiveMime.startsWith('image/') || /\.(jpg|jpeg|png|gif|webp|svg|bmp)(\?|$)/.test(lname) || /\.(jpg|jpeg|png|gif|webp|svg|bmp)(\?|$)/.test(lurl);

  const dlBtn = downloadAllowed
    ? `<a href="${fileUrl}" download="${filename}" target="_blank" style="display:inline-flex;align-items:center;gap:.4rem;padding:.4rem .9rem;background:rgba(0,255,136,.1);border:1px solid rgba(0,255,136,.25);border-radius:6px;color:var(--green);font-size:.78rem;text-decoration:none;cursor:pointer"><i class="fas fa-download"></i> Download</a>`
    : '';
  const newTabBtn = `<a href="${fileUrl}" target="_blank" style="display:inline-flex;align-items:center;gap:.4rem;padding:.4rem .9rem;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:6px;color:var(--muted);font-size:.78rem;text-decoration:none"><i class="fas fa-external-link-alt"></i> Open Tab</a>`;

  if (isPdf) {
    // Use PDF.js for reliable rendering — works with any Cloudinary URL
    openModal(`
      <div style="display:flex;align-items:center;justify-content:space-between;gap:.5rem;flex-wrap:wrap;padding:.8rem 1rem;background:rgba(10,26,18,.95);border-bottom:1px solid var(--border);border-radius:12px 12px 0 0;flex-shrink:0">
        <h3 style="font-size:.82rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:55%;color:var(--green)"><i class="fas fa-file-pdf"></i> ${filename}</h3>
        <div style="display:flex;gap:.4rem;align-items:center;flex-shrink:0">
          ${dlBtn} ${newTabBtn}
          <button onclick="closeModal()" style="background:rgba(239,68,68,.1);border:none;color:#ef4444;width:28px;height:28px;border-radius:6px;cursor:pointer;font-size:.9rem;display:flex;align-items:center;justify-content:center">×</button>
        </div>
      </div>
      <div id="pdf-render-area" style="flex:1;overflow-y:auto;background:#1a1a1a;display:flex;flex-direction:column;align-items:center;padding:1rem;gap:.5rem">
        <div id="pdf-dash-loading" style="color:#6b7280;padding:3rem;text-align:center"><div style="width:36px;height:36px;border:2px solid rgba(0,255,136,.12);border-top-color:#00ff88;border-radius:50%;animation:spin .7s linear infinite;margin:0 auto 1rem"></div>Loading PDF...</div>
      </div>
      <div style="display:flex;align-items:center;justify-content:center;gap:.75rem;padding:.6rem;background:rgba(10,26,18,.95);border-top:1px solid var(--border);flex-shrink:0">
        <button id="pdf-dash-prev" onclick="dashPdfPrev()" style="background:rgba(0,255,136,.08);border:1px solid rgba(0,255,136,.2);color:#00ff88;padding:.3rem .7rem;border-radius:5px;cursor:pointer;font-size:.78rem">◀ Prev</button>
        <span id="pdf-dash-info" style="color:#6b7280;font-size:.78rem">— / —</span>
        <button id="pdf-dash-next" onclick="dashPdfNext()" style="background:rgba(0,255,136,.08);border:1px solid rgba(0,255,136,.2);color:#00ff88;padding:.3rem .7rem;border-radius:5px;cursor:pointer;font-size:.78rem">Next ▶</button>
      </div>`, true);
    // Render with PDF.js
    renderDashPdf(fileUrl, filename);
  } else if (isImg) {
    openModal(`
      <div class="modal-hdr" style="display:flex;align-items:center;justify-content:space-between">
        <h3 style="font-size:.85rem"><i class="fas fa-image" style="color:var(--green)"></i> ${filename}</h3>
        <div style="display:flex;gap:.4rem">${dlBtn} ${newTabBtn} <button class="modal-close" onclick="closeModal()">×</button></div>
      </div>
      <div style="text-align:center;padding:1rem;overflow:auto;max-height:82vh">
        <img src="${fileUrl}" style="max-width:100%;max-height:78vh;border-radius:8px;object-fit:contain">
      </div>`);
  } else {
    openModal(`
      <div class="modal-hdr" style="display:flex;align-items:center;justify-content:space-between">
        <h3 style="font-size:.85rem"><i class="fas fa-file" style="color:var(--green)"></i> ${filename}</h3>
        <div style="display:flex;gap:.4rem">${dlBtn} ${newTabBtn} <button class="modal-close" onclick="closeModal()">×</button></div>
      </div>
      <div style="text-align:center;padding:3rem;color:var(--muted)">
        <i class="fas fa-file" style="font-size:3rem;margin-bottom:1rem;display:block;opacity:.4"></i>
        <p>Preview not available for this file type.</p>
      </div>`);
  }
}

// ── SEARCH ──
let searchTimeout;
document.getElementById('search-input').addEventListener('input',function(){
  clearTimeout(searchTimeout);
  const q=this.value.trim();
  if(q.length<2){document.getElementById('search-results').style.display='none';return;}
  searchTimeout=setTimeout(()=>doSearch(q),300);
});
document.addEventListener('click',e=>{if(!e.target.closest('.search-bar'))document.getElementById('search-results').style.display='none';});

async function doSearch(q){
  try{
    const d=await api('/files?personal=true');
    const results=(d.files||[]).filter(f=>(f.filename||'').toLowerCase().includes(q.toLowerCase()));
    const sr=document.getElementById('search-results');
    if(!results.length){sr.innerHTML='<div class="sr-item" style="color:var(--muted)">No results found</div>';sr.style.display='block';return;}
    sr.innerHTML=results.slice(0,8).map(f=>`<div class="sr-item" onclick="previewFile('${f.id}','${(f.filename||'').replace(/'/g,"\\'")}','${f.mimetype||''}');document.getElementById('search-results').style.display='none'">
      <i class="fas fa-file" style="color:var(--green);margin-right:.5rem;font-size:.8rem"></i>${f.filename}
      <span style="color:var(--muted);font-size:.7rem;margin-left:.5rem">${fmtSize(f.size)}</span>
    </div>`).join('');
    sr.style.display='block';
  }catch(e){}
}

// ── SOCKET.IO ──
let socket = null;
try{
  const tokenCookie = document.cookie.split('; ').find(r=>r.startsWith('token='));
  const token = tokenCookie ? tokenCookie.split('=')[1] : '';
  
  socket = io({
    auth: { token },
    reconnection: true,
    reconnectionDelay: 1000,
    reconnectionAttempts: 5
  });

  socket.on('connect', () => {
    console.log('Socket connected:', socket.id);
  });

  socket.on('disconnect', () => {
    console.log('Socket disconnected');
  });

  // ── INSTANT MESSAGE DELIVERY ──
  socket.on('new_message', (data) => {
    // Show toast notification
    toast(`💬 New message from ${data.fromUsername}`);
    refreshBadge();
    
    // If messages view is open and chat is with this sender, append instantly
    if (currentView === 'messages' && activeChatUser && activeChatUser.id === data.from) {
      appendMessage(data.text, false, data.createdAt);
      // Mark as read since user is viewing
      api(`/messages/${data.id}/read`, {method:'PUT'}).catch(()=>{});
    }
    
    // Update conversation list preview if visible
    const chatItem = document.querySelector(`.chat-item[data-uid="${data.from}"]`);
    if (chatItem) {
      const preview = chatItem.querySelector('.chat-item-preview');
      if (preview) preview.textContent = data.text;
    }
  });

  // Confirmation of sent message
  socket.on('message_sent', (data) => {
    // Message confirmed by server — already shown optimistically
  });

  socket.on('file_shared', (data) => {
    toast('📤 A file was shared with you');
    refreshBadge();
    if (currentView === 'shared') viewShared();
  });

  socket.on('file_approved', (data) => {
    toast('✅ Your file was approved');
    if (currentView === 'myfiles') viewMyFiles();
  });

  socket.on('new_broadcast', (data) => {
    toast('📢 New broadcast announcement');
    refreshBadge();
    if (currentView === 'broadcasts') viewBroadcasts();
  });

  socket.on('user_typing', (data) => {
    if (activeChatUser && activeChatUser.id === data.from) {
      const hdr = document.getElementById('chat-hdr-status');
      if (hdr) {
        hdr.textContent = data.isTyping ? 'typing...' : '';
      }
    }
  });

} catch(e) {
  console.warn('Socket.IO not available:', e.message);
}

// ── INIT ──
viewMyFiles();
refreshBadge();
setInterval(refreshBadge,30000);
</script>
</body>
</html>
