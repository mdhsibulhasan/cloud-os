      <span style="color:var(--muted)">/</span>
      <span style="color:var(--green);cursor:pointer" onclick="viewExplorer()">${subjectName}</span>
    </div>
    <div id="chapters-list"><div class="empty"><i class="fas fa-spinner fa-spin" style="font-size:1.5rem;opacity:.5"></i></div></div>`;
  try{
    const d=await api(`/subjects/${subjectId}/chapters`);
    if(!d.chapters||!d.chapters.length){
      document.getElementById('chapters-list').innerHTML=`<div class="empty"><i class="fas fa-folder-open"></i><p>No chapters in this subject yet.</p></div>`;
      return;
    }
    document.getElementById('chapters-list').innerHTML=`<div style="display:flex;flex-direction:column;gap:.6rem">
      ${d.chapters.map((c,i)=>`
        <div class="notif-item" style="cursor:pointer" onclick="loadExplorerFiles('${c.id}','${(c.name||'').replace(/'/g,"\\'")}','${subjectId}','${(subjectName||'').replace(/'/g,"\\'")}')">
          <div class="notif-icon" style="width:40px;height:40px;font-size:.9rem;border-radius:8px;flex-shrink:0">${i+1}</div>
          <div style="flex:1">
            <div style="font-size:.85rem;font-weight:600">${c.name}</div>
