// ── TOAST ──
function toast(msg,type='ok'){
  const t=document.getElementById('toast');
  t.className='toast'+(type==='err'?' err':'');
  t.innerHTML=(type==='err'?'<i class="fas fa-times-circle"></i>':'<i class="fas fa-check-circle"></i>')+' '+msg;
  t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3200);
}

// ── MODAL ──
function openModal(html, isPdf=false){
  const body = document.getElementById('modal-body');
  body.innerHTML = html;
  if(isPdf) body.classList.add('modal-pdf');
  else body.classList.remove('modal-pdf');
  document.getElementById('modal').classList.add('open');
}
function closeModal(){
  document.getElementById('modal').classList.remove('open');
  const body = document.getElementById('modal-body');
  body.innerHTML='';
  body.classList.remove('modal-pdf');
}
document.getElementById('modal').addEventListener('click',e=>{if(e.target===document.getElementById('modal'))closeModal();});

// ── API ──
async function api(url,opts={}){
  const r=await fetch('/api'+url,{...opts,credentials:'include',headers:{'Content-Type':'application/json',...(opts.headers||{})}});
  let d;
  try{d=await r.json();}catch(e){throw new Error('Server error ('+r.status+')');}
  if(!r.ok)throw new Error(d.message||'Request failed');
  return d;
}
async function apiForm(url,fd,method='POST'){
  const r=await fetch('/api'+url,{method,body:fd,credentials:'include'});
  let d;
  try{d=await r.json();}catch(e){throw new Error('Server error ('+r.status+')');}
  if(!r.ok)throw new Error(d.message||'Upload failed');
  return d;
}

// ── HELPERS ──
function fmtSize(b){if(!b||b===0)return'0 B';const k=1024,s=['B','KB','MB','GB'];const i=Math.floor(Math.log(b)/Math.log(k));return(b/Math.pow(k,i)).toFixed(1)+' '+s[i];}
function fmtDate(d){if(!d)return'';return new Date(d).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});}
function esc(s){return(s||'').replace(/'/g,"\\'").replace(/"/g,'&quot;');}
function loadingHTML(style=''){return`<div class="empty" ${style?`style="${style}"`:''}><div class="pdf-spinner" style="width:28px;height:28px;border-width:2px"></div></div>`;}
function animateCards(sel){document.querySelectorAll(sel).forEach((el,i)=>{setTimeout(()=>el.classList.add('loaded'),i*60);});}

// ── NAVIGATION ──
let currentView='myfiles';
document.querySelectorAll('.ni[data-view]').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.ni[data-view]').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    currentView=btn.dataset.view;
    const titles={myfiles:'My Files',shared:'Shared Files',explorer:'File Explorer',
      messages:'Messages',broadcasts:'Broadcasts',bookmarks:'Bookmarks',
      notifications:'Notifications',settings:'Settings'};
    const icons={myfiles:'fa-folder',shared:'fa-share-alt',explorer:'fa-compass',
      messages:'fa-comments',broadcasts:'fa-bullhorn',bookmarks:'fa-bookmark',
      notifications:'fa-bell',settings:'fa-cog'};
    document.getElementById('topbar-title').innerHTML=`<i class="fas ${icons[currentView]||'fa-circle'}"></i> ${titles[currentView]||''}`;
    const showSearch=['myfiles','shared','explorer','bookmarks'].includes(currentView);
    document.querySelector('.search-bar').style.display=showSearch?'flex':'none';
    document.querySelector('.btn-upload').style.display=currentView==='myfiles'?'flex':'none';
    loadView(currentView);
    if(window.innerWidth<768){sidebar.classList.remove('open');mobOverlay.classList.remove('open');}
  });
});

function loadView(v){
  const views={myfiles:viewMyFiles,shared:viewShared,explorer:viewExplorer,
    messages:viewMessages,broadcasts:viewBroadcasts,bookmarks:viewBookmarks,
    notifications:viewNotifications,settings:viewSettings};
  
  if(!views[v]) return;
  
  // Use smooth transition
  const content = document.getElementById('content');
  content.style.opacity = '0';
  content.style.transform = 'translateX(-20px)';
  content.style.transition = 'opacity 0.25s ease-in, transform 0.25s ease-in';
  
  setTimeout(() => {
    views[v]();
    
    // Scroll to top
    document.querySelector('.main').scrollTo({ top: 0, behavior: 'smooth' });
    
    // Enter animation
    requestAnimationFrame(() => {
      content.style.transition = 'opacity 0.35s cubic-bezier(0.16,1,0.3,1), transform 0.35s cubic-bezier(0.16,1,0.3,1)';
      content.style.opacity = '1';
      content.style.transform = 'translateX(0)';
    });
  }, 250);
}

