// ── MY FILES ──
async function viewMyFiles(){
  document.getElementById('content').innerHTML=`<div class="files-grid" id="files-grid"><div class="empty"><i class="fas fa-spinner fa-spin" style="animation:none;font-size:1.5rem;opacity:.5"></i></div></div>`;
  try{
    const d=await api('/files?personal=true');
    if(!d.files||!d.files.length){
      document.getElementById('files-grid').innerHTML=`<div class="empty" style="grid-column:1/-1"><i class="fas fa-folder-open"></i><p>No personal files yet. Upload your first file!</p><button class="btn-upload" onclick="openUploadModal()" style="margin-top:.5rem"><i class="fas fa-upload"></i> UPLOAD</button></div>`;
      return;
    }
    document.getElementById('files-grid').innerHTML=d.files.map(f=>fileCard(f,true)).join('');
    animateCards('.file-card');
  }catch(e){toast(e.message,'err');}
}

function fileCard(f,showActions=false){
  const thumb=f.thumbnailPath||'/assets/images/default-thumb.jpg';
  const cacheBuster = '?v=' + Date.now();
  return`<div class="file-card" onclick="previewFile('${f.id}','${(f.filename||'').replace(/'/g,"\\'")}','${f.mimetype||''}')">
    <img src="${thumb}${cacheBuster}" class="file-thumb" alt="${f.filename}" onerror="this.src='/assets/images/default-thumb.jpg${cacheBuster}'">
    <div class="file-body">
      <div class="file-name" title="${f.filename}">${f.filename}</div>
      <div class="file-meta">${fmtSize(f.size)} · ${fmtDate(f.createdAt)}</div>
      <div style="margin-bottom:.5rem"><span class="cat-badge">${f.category||'file'}</span></div>
      ${showActions?`<div class="file-actions" onclick="event.stopPropagation()">
        <button class="btn-xs btn-xs-green" onclick="openShareModal('${f.id}','${(f.filename||'').replace(/'/g,"\\'")}')"><i class="fas fa-share"></i></button>
        <button class="btn-xs btn-xs-red" onclick="deleteFile('${f.id}')"><i class="fas fa-trash"></i></button>
        ${f.downloadAllowed!==false?`<button class="btn-xs btn-xs-gray" onclick="downloadFile('${f.id}','${(f.filename||'').replace(/'/g,"\\'")}')"><i class="fas fa-download"></i></button>`:''}
      </div>`:''}
    </div>
  </div>`;
}

async function deleteFile(id){
  if(!confirm('Delete this file?'))return;
  try{await api(`/files/${id}`,{method:'DELETE'});toast('File deleted');viewMyFiles();}
  catch(e){toast(e.message,'err');}
}

async function downloadFile(id,name){
  try{
    const r=await fetch(`/api/files/preview/${id}`,{credentials:'include'});
    if(!r.ok)throw new Error('Download failed');
    const blob=await r.blob();
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a');a.href=url;a.download=name;
    document.body.appendChild(a);a.click();
    URL.revokeObjectURL(url);document.body.removeChild(a);
    toast('Download started');
  }catch(e){toast(e.message,'err');}
}

// ── SHARED FILES ──
async function viewShared(){
  document.getElementById('content').innerHTML=`<div class="files-grid" id="files-grid"><div class="empty" style="grid-column:1/-1"><i class="fas fa-spinner fa-spin" style="font-size:1.5rem;opacity:.5"></i></div></div>`;
  try{
    const d=await api('/files?shared=true');
    if(!d.files||!d.files.length){
      document.getElementById('files-grid').innerHTML=`<div class="empty" style="grid-column:1/-1"><i class="fas fa-share-alt"></i><p>No files shared with you yet.</p></div>`;
      return;
    }
    document.getElementById('files-grid').innerHTML=d.files.map(f=>fileCard(f,false)).join('');
    animateCards('.file-card');
  }catch(e){toast(e.message,'err');}
}

// ── BOOKMARKS ──
async function viewBookmarks(){
  const c=document.getElementById('content');
  c.innerHTML=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem">
    <h3 style="font-size:.95rem;font-weight:700"><i class="fas fa-bookmark" style="color:var(--green)"></i> My Bookmarks</h3>
  </div>
  <div id="bookmarks-grid" class="files-grid">${loadingHTML('grid-column:1/-1')}</div>`;
  try{
    const d=await api('/bookmarks');
    const grid=document.getElementById('bookmarks-grid');
    if(!d.bookmarks||!d.bookmarks.length){
      grid.innerHTML=`<div class="empty" style="grid-column:1/-1"><div class="empty-icon"><i class="fas fa-bookmark"></i></div><p>No bookmarks yet.<br><span style="font-size:.78rem;color:var(--muted)">Bookmark files from the Explorer to find them here quickly.</span></p></div>`;
      return;
    }
    const cb='?v='+Date.now();
    grid.innerHTML=d.bookmarks.map(f=>`
      <div class="file-card">
        <img src="${f.thumbnailPath||'/assets/images/default-thumb.jpg'}${cb}" class="file-thumb" alt="${f.filename}" loading="lazy"
             onerror="this.src='/assets/images/default-thumb.jpg${cb}'">
        <div class="file-body">
          <div class="file-name" title="${f.filename}">${f.filename}</div>
          <div class="file-meta">${fmtSize(f.size)} &middot; ${fmtDate(f.createdAt)}</div>
          <span class="cat-badge">${f.category||'file'}</span>
          <div class="file-btns" style="margin-top:.6rem">
            <button class="btn-xs btn-g" onclick="previewFile('${esc(f.id)}','${esc(f.filename)}','${f.mimetype||''}')">
              <i class="fas fa-eye"></i> View
            </button>
            ${f.downloadAllowed!==false?`<button class="btn-xs btn-b" onclick="downloadFile('${esc(f.id)}','${esc(f.filename)}')"><i class="fas fa-download"></i></button>`:''}
            <button class="btn-xs" style="background:rgba(239,68,68,.1);color:#ef4444;border:1px solid rgba(239,68,68,.2)" onclick="removeBookmark('${esc(f.id)}')">
              <i class="fas fa-bookmark"></i>
            </button>
          </div>
        </div>
      </div>`).join('');
  }catch(e){
    document.getElementById('bookmarks-grid').innerHTML=`<div class="empty" style="grid-column:1/-1"><i class="fas fa-exclamation-circle" style="color:#ef4444"></i><p>${e.message}</p></div>`;
  }
}

async function removeBookmark(fileId){
  try{
    await api(`/bookmarks/${fileId}`,{method:'DELETE'});
    toast('Bookmark removed');
    viewBookmarks();
  }catch(e){toast(e.message,'err');}
}

async function addBookmark(fileId,filename){
  try{
    await api('/bookmarks',{method:'POST',body:JSON.stringify({fileId})});
    toast(`"${filename}" bookmarked`);
  }catch(e){toast(e.message,'err');}
}
</script>

<script>
// ── FILE EXPLORER (SUBJECTS) ──
let explorerState={view:'subjects',subjectId:null,subjectName:'',chapterId:null,chapterName:''};

async function viewExplorer(){
  explorerState={view:'subjects',subjectId:null,subjectName:'',chapterId:null,chapterName:''};
  await loadExplorerSubjects();
}

async function loadExplorerSubjects(){
  document.getElementById('content').innerHTML=`
    <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.2rem;padding:.7rem 1rem;background:rgba(10,26,18,.7);border:1px solid var(--border);border-radius:9px">
      <i class="fas fa-home" style="color:var(--green)"></i>
      <span style="font-size:.82rem;color:var(--muted)">Archive</span>
    </div>
    <div class="search-bar" style="margin-bottom:1.2rem;display:flex">
      <i class="fas fa-search"></i>
      <input type="text" placeholder="Search the archive..." id="explorer-search" oninput="filterSubjects(this.value)">
    </div>
    <div id="subjects-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:1rem">
      <div class="empty" style="grid-column:1/-1"><i class="fas fa-spinner fa-spin" style="font-size:1.5rem;opacity:.5"></i></div>
    </div>`;
  try{
    const d=await api('/subjects');
    window._allSubjects=d.subjects||[];
    renderSubjectCards(window._allSubjects);
  }catch(e){toast(e.message,'err');}
}

function renderSubjectCards(subjects){
  const grid=document.getElementById('subjects-grid');
  if(!subjects.length){
    grid.innerHTML=`<div class="empty" style="grid-column:1/-1"><i class="fas fa-book-open"></i><p>No subjects available yet.</p></div>`;
    return;
  }
  grid.innerHTML=subjects.map(s=>`
    <div class="file-card" style="text-align:center;padding:0" onclick="loadExplorerChapters('${s.id}','${(s.name||'').replace(/'/g,"\\'")}')">
      <div style="padding:1.5rem 1rem 1rem">
        <div style="width:52px;height:52px;background:rgba(0,255,136,.12);border:1px solid rgba(0,255,136,.3);border-radius:10px;display:flex;align-items:center;justify-content:center;margin:0 auto .8rem;font-size:1.4rem;color:var(--green)">
          <i class="fas fa-book-open"></i>
        </div>
        <div style="font-size:.83rem;font-weight:700;margin-bottom:.3rem">${s.name}</div>
        <div style="font-size:.7rem;color:var(--muted)">${s.chapterCount||0} chapters · ${s.fileCount||0} files</div>
      </div>
    </div>`).join('');
  animateCards('.file-card');
}

function filterSubjects(q){
  if(!window._allSubjects)return;
  const filtered=window._allSubjects.filter(s=>s.name.toLowerCase().includes(q.toLowerCase()));
  renderSubjectCards(filtered);
}

async function loadExplorerChapters(subjectId,subjectName){
  explorerState={view:'chapters',subjectId,subjectName,chapterId:null,chapterName:''};
  document.getElementById('content').innerHTML=`
    <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:1.2rem;padding:.7rem 1rem;background:rgba(10,26,18,.7);border:1px solid var(--border);border-radius:9px;font-size:.82rem">
