<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard — CloudOS</title>
<link rel="icon" href="/assets/images/favicon.png" type="image/png">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --green:#00ff88;--bg:#050d0a;--bg2:#0a1a12;--bg3:#0d2018;
  --sw:200px;--border:rgba(0,255,136,0.15);--text:#e2e8f0;--muted:#6b7280;
}
html,body{height:100%;overflow:hidden}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);display:flex}

/* ── CANVAS ── */
#bg-canvas{position:fixed;inset:0;z-index:0;pointer-events:none}

/* ── SIDEBAR ── */
.sidebar{
  width:var(--sw);min-width:var(--sw);height:100vh;
  background:rgba(6,14,10,0.97);border-right:1px solid var(--border);
  display:flex;flex-direction:column;position:fixed;left:0;top:0;z-index:50;
  overflow-y:auto;transition:transform .3s ease;
}
.sb-brand{
  display:flex;align-items:center;gap:.55rem;padding:1rem 1rem .6rem;
  color:var(--green);font-weight:700;font-size:1rem;text-decoration:none;
  border-bottom:1px solid var(--border);
}
.sb-brand i{font-size:1rem}
.sb-profile{
  display:flex;align-items:center;gap:.65rem;padding:.85rem .9rem;
  border-bottom:1px solid var(--border);
}
.sb-avatar{
  width:36px;height:36px;border-radius:50%;border:2px solid var(--green);
  object-fit:cover;box-shadow:0 0 10px rgba(0,255,136,.3);flex-shrink:0;
}
.sb-name{font-size:.8rem;font-weight:700;line-height:1.2}
.sb-role{font-size:.68rem;color:var(--green)}
.sb-nav{flex:1;padding:.5rem .5rem 0}
.ni{
  display:flex;align-items:center;gap:.65rem;padding:.6rem .75rem;
  border-radius:7px;color:var(--muted);font-size:.8rem;cursor:pointer;
  transition:background .15s,color .15s,transform .15s;
  border:none;background:none;width:100%;text-align:left;
  margin-bottom:2px;text-decoration:none;position:relative;
  opacity:0;transform:translateX(-20px);
}
.ni.loaded{opacity:1;transform:translateX(0)}
.ni i{width:15px;text-align:center;font-size:.82rem;flex-shrink:0}
.ni:hover{background:rgba(0,255,136,.08);color:var(--green);transform:translateX(3px)}
.ni.active{background:rgba(0,255,136,.13);color:var(--green);font-weight:600}
.ni .badge{
  margin-left:auto;min-width:18px;height:18px;padding:0 5px;
  background:var(--green);color:#050d0a;border-radius:9px;
  font-size:.65rem;font-weight:700;display:flex;align-items:center;justify-content:center;
}
.sb-footer{padding:.6rem .5rem;border-top:1px solid var(--border)}

/* ── MAIN ── */
.main{margin-left:var(--sw);flex:1;height:100vh;overflow-y:auto;position:relative;z-index:1}
.content{padding:1.5rem;transition:opacity 0.35s cubic-bezier(0.16,1,0.3,1), transform 0.35s cubic-bezier(0.16,1,0.3,1)}
.topbar{
  display:flex;align-items:center;gap:1rem;padding:.9rem 1.5rem;
  background:rgba(5,13,10,.9);backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);position:sticky;top:0;z-index:10;
}
.topbar-title{display:flex;align-items:center;gap:.6rem;font-weight:700;font-size:1rem;white-space:nowrap}
.topbar-title i{color:var(--green)}
.search-bar{
  flex:1;display:flex;align-items:center;gap:.6rem;
  background:rgba(0,255,136,.04);border:1px solid rgba(0,255,136,.2);
  border-radius:8px;padding:.5rem .9rem;transition:border-color .2s,box-shadow .2s;
}
.search-bar:focus-within{border-color:var(--green);box-shadow:0 0 0 3px rgba(0,255,136,.08)}
.search-bar i{color:var(--muted);font-size:.85rem}
.search-bar input{background:none;border:none;color:var(--text);font-size:.85rem;width:100%;outline:none;font-family:inherit}
.search-bar input::placeholder{color:var(--muted)}
.btn-upload{
  display:flex;align-items:center;gap:.5rem;padding:.5rem 1.1rem;
  background:transparent;border:1.5px solid var(--green);border-radius:7px;
  color:var(--green);font-size:.8rem;font-weight:700;cursor:pointer;
  transition:background .2s,box-shadow .2s;white-space:nowrap;
}
.btn-upload:hover{background:rgba(0,255,136,.1);box-shadow:0 0 15px rgba(0,255,136,.25)}

.content{padding:1.5rem}

/* ── FILE CARDS ── */
.files-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem}
.file-card{
  background:rgba(10,26,18,.75);border:1px solid var(--border);border-radius:10px;
  overflow:hidden;cursor:pointer;transition:border-color .2s,box-shadow .2s,transform .2s;
  opacity:0;transform:translateY(20px);
}
.file-card.loaded{opacity:1;transform:translateY(0)}
.file-card:hover{border-color:var(--green);box-shadow:0 0 20px rgba(0,255,136,.15);transform:translateY(-3px)}
.file-thumb{width:100%;height:130px;object-fit:cover;display:block;background:#0a1a12}
.file-body{padding:.8rem}
.file-name{font-size:.82rem;font-weight:600;margin-bottom:.4rem;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.file-meta{font-size:.7rem;color:var(--muted);margin-bottom:.6rem}
.file-actions{display:flex;gap:.4rem}
.btn-xs{
  display:inline-flex;align-items:center;gap:.3rem;padding:.3rem .65rem;
  border-radius:5px;font-size:.72rem;font-weight:600;cursor:pointer;border:none;
  transition:all .15s;
}
.btn-xs-green{background:rgba(0,255,136,.1);color:var(--green);border:1px solid rgba(0,255,136,.25)}
.btn-xs-green:hover{background:rgba(0,255,136,.2)}
.btn-xs-red{background:rgba(239,68,68,.1);color:#ef4444;border:1px solid rgba(239,68,68,.2)}
.btn-xs-red:hover{background:rgba(239,68,68,.2)}
.btn-xs-gray{background:rgba(255,255,255,.06);color:var(--muted);border:1px solid rgba(255,255,255,.1)}
.btn-xs-gray:hover{background:rgba(255,255,255,.1);color:var(--text)}
.cat-badge{
  display:inline-block;padding:.15rem .5rem;border-radius:4px;font-size:.65rem;font-weight:600;
  background:rgba(0,255,136,.1);color:var(--green);border:1px solid rgba(0,255,136,.2);
}

/* ── EMPTY STATE ── */
.empty{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:5rem 2rem;color:var(--muted);text-align:center;
}
.empty i{font-size:3.5rem;color:rgba(0,255,136,.3);margin-bottom:1rem;
  animation:floatIcon 3s ease-in-out infinite}
@keyframes floatIcon{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
.empty p{font-size:.9rem;margin-bottom:1.2rem}

/* ── NOTIFICATION ITEMS ── */
.notif-item{
  display:flex;align-items:flex-start;gap:.9rem;padding:.9rem;
  background:rgba(10,26,18,.7);border:1px solid var(--border);border-radius:9px;
  margin-bottom:.6rem;transition:border-color .2s;
  opacity:0;transform:translateX(-15px);
}
.notif-item.loaded{opacity:1;transform:translateX(0)}
.notif-item.unread{border-left:3px solid var(--green)}
.notif-item:hover{border-color:rgba(0,255,136,.35)}
.notif-icon{
  width:34px;height:34px;border-radius:50%;flex-shrink:0;
  background:rgba(0,255,136,.1);border:1px solid rgba(0,255,136,.2);
  display:flex;align-items:center;justify-content:center;color:var(--green);font-size:.85rem;
}
.notif-msg{font-size:.82rem;line-height:1.5}
.notif-time{font-size:.7rem;color:var(--muted);margin-top:.2rem}

/* ── BROADCAST ITEMS ── */
.bc-item{
  background:rgba(10,26,18,.7);border:1px solid var(--border);border-radius:9px;
  padding:1rem 1.2rem;margin-bottom:.7rem;transition:border-color .2s;
  opacity:0;transform:translateY(10px);
}
.bc-item.loaded{opacity:1;transform:translateY(0)}
.bc-item.pinned{border-left:3px solid var(--green)}
.bc-item:hover{border-color:rgba(0,255,136,.3)}
.bc-msg{font-size:.85rem;line-height:1.6;margin-bottom:.4rem}
.bc-time{font-size:.7rem;color:var(--muted)}

/* ── CHAT ── */
.chat-layout{display:grid;grid-template-columns:240px 1fr;gap:1rem;height:calc(100vh - 130px);min-height:400px}
.chat-list{background:rgba(10,26,18,.7);border:1px solid var(--border);border-radius:10px;overflow-y:auto}
.chat-item{padding:.85rem 1rem;border-bottom:1px solid var(--border);cursor:pointer;transition:background .15s;user-select:none}
.chat-item:hover,.chat-item.active{background:rgba(0,255,136,.07)}
.chat-item-name{font-size:.83rem;font-weight:600}
.chat-item-preview{font-size:.72rem;color:var(--muted);margin-top:.15rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.chat-win{background:rgba(10,26,18,.7);border:1px solid var(--border);border-radius:10px;display:flex;flex-direction:column;overflow:hidden}
.chat-hdr{padding:.9rem 1.2rem;border-bottom:1px solid var(--border);font-weight:700;font-size:.88rem;display:flex;align-items:center;gap:.6rem;flex-shrink:0;background:rgba(0,0,0,.2)}
.chat-msgs{flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:.6rem;scroll-behavior:smooth}
.msg{max-width:72%;padding:.65rem .95rem;border-radius:12px;font-size:.83rem;line-height:1.55;word-break:break-word}
.msg-in{background:rgba(0,255,136,.07);border:1px solid rgba(0,255,136,.15);align-self:flex-start;border-bottom-left-radius:4px}
.msg-out{background:rgba(0,255,136,.15);border:1px solid rgba(0,255,136,.28);align-self:flex-end;border-bottom-right-radius:4px}
.msg-time{font-size:.65rem;color:var(--muted);margin-top:.3rem;text-align:right}
.msg-in .msg-time{text-align:left}
.chat-inp{padding:.85rem;border-top:1px solid var(--border);display:flex;gap:.6rem;flex-shrink:0;background:rgba(0,0,0,.15)}
.chat-inp input{flex:1;padding:.62rem .9rem;background:rgba(0,255,136,.04);border:1px solid rgba(0,255,136,.2);border-radius:8px;color:var(--text);font-size:.85rem;font-family:inherit;transition:border-color .2s,box-shadow .2s}
.chat-inp input:focus{outline:none;border-color:var(--green);box-shadow:0 0 0 3px rgba(0,255,136,.08)}
@keyframes msgBubbleIn{from{opacity:0;transform:translateY(8px) scale(.95)}to{opacity:1;transform:translateY(0) scale(1)}}

/* ── SETTINGS ── */
.settings-card{background:rgba(10,26,18,.7);border:1px solid var(--border);border-radius:10px;padding:1.8rem;max-width:500px}
.form-group{margin-bottom:1rem}
.form-label{display:block;font-size:.75rem;color:var(--muted);margin-bottom:.35rem;font-weight:600}
.form-input,.form-select,.form-textarea{
  width:100%;padding:.65rem .9rem;background:rgba(0,255,136,.04);
  border:1px solid rgba(0,255,136,.2);border-radius:7px;color:var(--text);
  font-size:.85rem;font-family:inherit;transition:border-color .2s,box-shadow .2s;
}
.form-input:focus,.form-select:focus,.form-textarea:focus{outline:none;border-color:var(--green);box-shadow:0 0 0 3px rgba(0,255,136,.08)}
.form-textarea{resize:vertical;min-height:80px}
.form-select option{background:var(--bg2)}
.btn-save{
  width:100%;padding:.75rem;background:transparent;border:1.5px solid var(--green);
  border-radius:8px;color:var(--green);font-weight:700;font-size:.88rem;cursor:pointer;
  transition:background .2s,box-shadow .2s;display:flex;align-items:center;justify-content:center;gap:.5rem;
}
.btn-save:hover{background:rgba(0,255,136,.1);box-shadow:0 0 18px rgba(0,255,136,.25)}
.prof-preview{width:80px;height:80px;border-radius:50%;border:2px solid var(--green);object-fit:cover;margin-bottom:1rem}

/* ── MODAL ── */
.modal-ov{
  position:fixed;inset:0;background:rgba(0,0,0,.88);backdrop-filter:blur(6px);
  z-index:200;display:none;align-items:center;justify-content:center;padding:1rem;
}
.modal-ov.open{display:flex}
.modal{
  background:var(--bg2);border:1px solid var(--border);border-radius:12px;
  padding:1.5rem;width:min(520px,96vw);max-height:92vh;overflow-y:auto;
  box-shadow:0 20px 60px rgba(0,0,0,.6);
  animation:modalIn .25s ease-out;
}
.modal.modal-pdf{
  padding:0;width:min(900px,96vw);height:92vh;max-height:92vh;
  display:flex;flex-direction:column;overflow:hidden;
}@keyframes modalIn{from{opacity:0;transform:scale(.92)}to{opacity:1;transform:scale(1)}}
.modal-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.3rem}
.modal-hdr h3{font-size:.95rem;font-weight:700}
.modal-close{background:none;border:none;color:var(--muted);font-size:1.3rem;cursor:pointer;padding:.2rem;line-height:1}
.modal-close:hover{color:var(--text)}
.modal-footer{display:flex;gap:.7rem;margin-top:1.3rem;justify-content:flex-end}

/* ── TOAST ── */
.toast{
  position:fixed;bottom:1.5rem;right:1.5rem;z-index:999;
  background:var(--bg2);border:1px solid var(--green);border-radius:10px;
  padding:.85rem 1.3rem;color:var(--green);font-size:.83rem;
  transform:translateY(80px);opacity:0;transition:transform .3s,opacity .3s;
  display:flex;align-items:center;gap:.55rem;
}
.toast.show{transform:translateY(0);opacity:1}
.toast.err{border-color:#ef4444;color:#ef4444}

/* ── HAMBURGER ── */
.hamburger{
  display:none;position:fixed;top:.8rem;left:.8rem;z-index:100;
  background:var(--bg2);border:1px solid var(--border);border-radius:7px;
  width:38px;height:38px;align-items:center;justify-content:center;
  cursor:pointer;color:var(--green);font-size:1rem;
}
.mob-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:49}

/* ── SEARCH RESULTS ── */
.search-results{
  position:absolute;top:100%;left:0;right:0;margin-top:.3rem;
  background:var(--bg2);border:1px solid var(--border);border-radius:9px;
  max-height:300px;overflow-y:auto;z-index:50;
  box-shadow:0 10px 30px rgba(0,0,0,.5);
}
.sr-item{padding:.75rem 1rem;cursor:pointer;border-bottom:1px solid var(--border);transition:background .15s;font-size:.83rem}
.sr-item:hover{background:rgba(0,255,136,.07)}
.sr-item:last-child{border-bottom:none}

/* ── RESPONSIVE ── */
@media(max-width:768px){
  .sidebar{transform:translateX(-100%)}
  .sidebar.open{transform:translateX(0)}
  .main{margin-left:0}
  .hamburger{display:flex}
  .mob-overlay.open{display:block}
  .files-grid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr))}
  .chat-layout{grid-template-columns:1fr;height:auto}
  .topbar{padding:.7rem 1rem}
}
</style>
</head>
<body>
<canvas id="bg-canvas"></canvas>
<button class="hamburger" id="hamburger"><i class="fas fa-bars"></i></button>
<div class="mob-overlay" id="mob-overlay"></div>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <a href="/" class="sb-brand"><i class="fas fa-cloud"></i> CloudOS</a>
  <div class="sb-profile">
    <img src="<%= user.profilePicture %>?v=<%= Date.now() %>" class="sb-avatar" id="sb-avatar"
         onerror="this.src='data:image/svg+xml;base64,'">
    <div>
      <div class="sb-name" id="sb-name"><%= user.username %></div>
      <div class="sb-role"><%= user.role === 'admin' ? 'System Admin' : user.role === 'owner' ? '👑 Owner' : user.role === 'moderator' ? 'Moderator' : 'Approved User' %></div>
    </div>
  </div>
  <nav class="sb-nav" id="sb-nav">
    <button class="ni active" data-view="myfiles"><i class="fas fa-folder"></i> My Files</button>
    <button class="ni" data-view="shared"><i class="fas fa-share-alt"></i> Shared</button>
    <button class="ni" data-view="explorer"><i class="fas fa-compass"></i> File Explorer</button>
    <button class="ni" data-view="messages"><i class="fas fa-comments"></i> Messages</button>
    <button class="ni" data-view="broadcasts"><i class="fas fa-bullhorn"></i> Broadcasts</button>
    <button class="ni" data-view="bookmarks"><i class="fas fa-bookmark"></i> Bookmarks</button>
    <button class="ni" data-view="notifications"><i class="fas fa-bell"></i> Notifications<span class="badge" id="notif-badge" style="display:none">0</span></button>
    <button class="ni" data-view="settings"><i class="fas fa-cog"></i> Settings</button>
    <% if (user.role === 'admin' || user.role === 'moderator' || user.role === 'owner') { %>
    <a href="/admin" class="ni" style="margin-top:.5rem"><i class="fas fa-shield-alt"></i> <%= user.role === 'owner' ? '👑 Owner Panel' : user.role === 'admin' ? 'Admin Panel' : 'Moderator Panel' %></a>
    <% } %>
  </nav>
  <div class="sb-footer">
    <button class="ni" onclick="doLogout()"><i class="fas fa-sign-out-alt"></i> Logout</button>
  </div>
</aside>

<!-- MAIN -->
<main class="main" id="main">
  <div class="topbar">
    <div class="topbar-title" id="topbar-title"><i class="fas fa-folder"></i> My Files</div>
    <div class="search-bar" style="position:relative">
      <i class="fas fa-search"></i>
      <input type="text" id="search-input" placeholder="Search files...">
      <div class="search-results" id="search-results" style="display:none"></div>
    </div>
    <button class="btn-upload" onclick="openUploadModal()"><i class="fas fa-upload"></i> UPLOAD</button>
  </div>
  <div class="content" id="content"></div>
</main>

<!-- MODAL -->
<div class="modal-ov" id="modal"><div class="modal" id="modal-body"></div></div>
<div class="toast" id="toast"></div>

<script src="https://cdn.socket.io/4.6.1/socket.io.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
let _dashPdfDoc=null, _dashPdfPage=1;

async function renderDashPdf(url, filename){
  // Use iframe — works with B2 signed URLs, no CORS issues
  const area=document.getElementById('pdf-render-area');
  if(!area) return;
  area.innerHTML=`<iframe src="${url}" style="width:100%;height:100%;border:none;min-height:75vh;display:block;border-radius:0 0 10px 10px"></iframe>`;
  const info=document.getElementById('pdf-dash-info');
  if(info) info.textContent='PDF loaded';
}

async function _renderDashPage(num){
  if(!_dashPdfDoc) return;
  const area=document.getElementById('pdf-render-area');
  if(!area) return;
  const page = await _dashPdfDoc.getPage(num);
  const areaW = area.clientWidth - 32;
  const vp = page.getViewport({scale:1});
  const scale = Math.min(areaW/vp.width, 2);
  const scaledVp = page.getViewport({scale});
  const canvas = document.createElement('canvas');
  canvas.width=scaledVp.width; canvas.height=scaledVp.height;
  canvas.style.cssText='border-radius:4px;box-shadow:0 2px 12px rgba(0,0,0,.5);max-width:100%';
  area.innerHTML='';
  area.appendChild(canvas);
  await page.render({canvasContext:canvas.getContext('2d'),viewport:scaledVp}).promise;
  const info=document.getElementById('pdf-dash-info');
  if(info) info.textContent=`${num} / ${_dashPdfDoc.numPages}`;
}

async function dashPdfPrev(){if(_dashPdfDoc&&_dashPdfPage>1){_dashPdfPage--;await _renderDashPage(_dashPdfPage);}}
async function dashPdfNext(){if(_dashPdfDoc&&_dashPdfPage<_dashPdfDoc.numPages){_dashPdfPage++;await _renderDashPage(_dashPdfPage);}}

// ── SPACE CANVAS ──
(function(){
  const c=document.getElementById('bg-canvas'),ctx=c.getContext('2d');
  let W,H,pts=[],shapes=[];
  function resize(){W=c.width=window.innerWidth;H=c.height=window.innerHeight;}
  // Particles
  function P(){this.reset(true)}
  P.prototype.reset=function(init){
    this.x=Math.random()*W;this.y=init?Math.random()*H:H+10;
    this.r=Math.random()<.1?Math.random()*3+2:Math.random()*1.5+.4;
    this.sq=Math.random()<.09;this.sp=Math.random()*.22+.04;
    this.a=Math.random()*.55+.12;this.tw=Math.random()*Math.PI*2;
    this.ts=Math.random()*.025+.008;
  };
  P.prototype.draw=function(){
    const a=this.a*(.55+.45*Math.sin(this.tw));
    ctx.globalAlpha=a;ctx.fillStyle='#00ff88';
    if(this.sq)ctx.fillRect(this.x-this.r,this.y-this.r,this.r*2,this.r*2);
    else{ctx.beginPath();ctx.arc(this.x,this.y,this.r,0,Math.PI*2);ctx.fill();}
    ctx.globalAlpha=1;
  };
  P.prototype.update=function(){
    this.y-=this.sp;this.tw+=this.ts;
    if(this.y+this.r<0)this.reset(false);
  };
  // Wireframe shapes
  function makeIco(cx,cy,r){
    const pts=[];const phi=(1+Math.sqrt(5))/2;
    const raw=[[0,1,phi],[0,-1,phi],[0,1,-phi],[0,-1,-phi],[1,phi,0],[-1,phi,0],[1,-phi,0],[-1,-phi,0],[phi,0,1],[phi,0,-1],[-phi,0,1],[-phi,0,-1]];
    const edges=[[0,1],[0,4],[0,5],[0,8],[0,10],[1,6],[1,7],[1,8],[1,10],[2,3],[2,4],[2,5],[2,9],[2,11],[3,6],[3,7],[3,9],[3,11],[4,8],[4,9],[5,10],[5,11],[6,8],[6,9],[7,10],[7,11],[8,9],[10,11]];
    const norm=Math.sqrt(1+phi*phi);
    return{cx,cy,r,pts:raw.map(p=>[p[0]/norm,p[1]/norm,p[2]/norm]),edges,rot:0,rotSpeed:Math.random()*.008+.003,alpha:0.18+Math.random()*.1};
  }
  function drawShape(s){
    const cos=Math.cos(s.rot),sin=Math.sin(s.rot);
    const proj=s.pts.map(p=>{
      const x2=p[0]*cos-p[2]*sin,z2=p[0]*sin+p[2]*cos;
      return[s.cx+x2*s.r,s.cy+p[1]*s.r];
    });
    ctx.strokeStyle='#00ff88';ctx.lineWidth=.8;ctx.globalAlpha=s.alpha;
    s.edges.forEach(e=>{
      ctx.beginPath();ctx.moveTo(proj[e[0]][0],proj[e[0]][1]);
      ctx.lineTo(proj[e[1]][0],proj[e[1]][1]);ctx.stroke();
    });
    ctx.globalAlpha=1;
  }
  function init(){
    resize();
    pts=Array.from({length:160},()=>new P());
    shapes=[
      makeIco(W*.28,H*.55,38),
      makeIco(W*.55,H*.62,28),
      makeIco(W*.72,H*.45,22),
    ];
  }
  function loop(){
    ctx.clearRect(0,0,W,H);
    pts.forEach(p=>{p.update();p.draw();});
    shapes.forEach(s=>{s.rot+=s.rotSpeed;drawShape(s);});
    requestAnimationFrame(loop);
  }
  window.addEventListener('resize',()=>{resize();shapes[0].cx=W*.28;shapes[0].cy=H*.55;shapes[1].cx=W*.55;shapes[1].cy=H*.62;shapes[2].cx=W*.72;shapes[2].cy=H*.45;});
  init();loop();
})();

